  "description": "Search a sorted array in O(log n) by halving the search space each iteration.",
  "patternSlug": "binary-search",
  "language": "python",
  "code": "def binary_search(arr, target):\n    lo, hi = 0, len(arr) - 1\n\n    while lo <= hi:\n        mid = lo + (hi - lo) // 2\n\n        if arr[mid] == target:\n            return mid\n        elif arr[mid] < target:\n            lo = mid + 1\n        else:\n            hi = mid - 1\n\n    return -1",
