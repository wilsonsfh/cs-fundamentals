  "title": "Sliding Window — Longest Substring",
  "description": "Find the longest substring without repeating characters using a variable-size sliding window.",
  "patternSlug": "sliding-window",
  "language": "python",
  "code": "def length_of_longest(s):\n    left = 0\n    char_set = set()\n    result = 0\n\n    for right in range(len(s)):\n        while s[right] in char_set:\n            char_set.remove(s[left])\n            left += 1\n        char_set.add(s[right])\n        result = max(result, right - left + 1)\n\n    return result",
  "input": "s = \"abcab\"",
  "output": "3",
